# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.hypothesis/
.coverage
htmlcov/

# Build / run artifacts. Track the empty out/ folder (.gitkeep), never its contents.
out/*
!out/.gitkeep
dist/
build/
.cache/
marker_out/
# generated by the billed vision runner; schema evolves
eval/corpus/*/vision_structure.json

# Inputs live locally only. Track the sample/ folder (.gitkeep), never the theses in it.
sample/*
!sample/.gitkeep

# Secrets (never commit API keys; they come from the environment)
.env
*.key

# OS
.DS_Store

# Local tooling
.claude/

# Stray local exports (NotebookLM/browser downloads), not project source
Thesis Audiobook*.html
